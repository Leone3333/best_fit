<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="/stylesheets/fichas.css">
    <title>BestFit - Fichas</title>
</head>

<body>

    <header class="header-fichas">
        <h2>
            <%= edicao ? 'Editar ficha' : 'Selecionar ficha' %>
        </h2>
        <div class="status-icon">
            <span class="material-symbols-outlined" onclick="confirmarSair()">
                exit_to_app
            </span>
        </div>
    </header>

    <main class="container">
        <% fichas.forEach(f=> { %>
            <div class="ficha-card">
                <div class="ficha-info">
                    <h3>
                        Grupo <%= f.divisao %>
                    </h3>
                </div>

                <div class="status-icon">
                    <% if (!edicao) { %>
                        <% if (f.status_ficha===0) { %>
                            <a style="text-decoration: none; color: inherit;"
                                href="/fichas/treinosSelecao?id=<%= f.idficha %>"> <span
                                    class="material-symbols-outlined">check_box_outline_blank</span> </a>
                            <% } else { %>
                                <a style="text-decoration: none; color: inherit;"
                                    href="/fichas/treinosSelecao?id=<%= f.idficha %>"> <span
                                        class="material-symbols-outlined">check_box</span>
                                </a>
                                <% } %>
                                    <% } else { %>
                                        <a style="text-decoration: none; color: inherit;"
                                            href="/fichas/treinosEdicao?id=<%=f.idficha%>"> <span
                                                class="material-symbols-outlined">arrow_forward</span> </a>
                                        <% } %>
                </div>
            </div>
            <% }) %>
    </main>

    <% if (!edicao) { %>
        <div class="btn-float">
            <a href="/fichas/edit" style="text-decoration: none; color: inherit;">
                <span class="material-symbols-outlined">edit</span>
            </a>
        </div>
        <% } %>

            <nav class="bottom-nav">
                <% if (edicao) { %>
                    <div class="nav-item-circle" style="width: 40px; height: 40px; position: absolute; left: 20px;">
                        <div class="icon-label">
                            <a href="/fichas" style="text-decoration: none; color: inherit;">
                                <span class="material-symbols-outlined">arrow_back</span>
                            </a>
                        </div>
                    </div>
                    <% } %>

                        <div class="nav-item-circle"
                            style="width: 65px; height: 65px; border: 4px solid var(--bg-dark); margin-top: -40px;">
                            <div class="icon-label">
                                <span class="material-symbols-outlined">home</span>
                            </div>
                        </div>
            </nav>

</body>
<script src="/javascripts/logout.js"></script>

</html>