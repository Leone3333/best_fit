<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="/stylesheets/treinosEdicao.css">
    <title>BestFit - Exercícios</title>
</head>

<body>

    <header class="header-exercicios">
        <h1>Ficha <%=fichaTreinos[0].divisao %>
        </h1>
        <div class="status-icon">
            <span class="material-symbols-outlined" onclick="confirmarSair()">
                exit_to_app
            </span>
        </div>
    </header>

    <div class="table-header">
        <div class="col-ex">Exercicio</div>
        <div class="col-sm">serie</div>
        <div class="col-sm">rep</div>
        <div class="col-sm">Carga</div>
        <div class="col-btns"></div> <!-- ESSENCIAL para alinhar -->
    </div>

    <main id="exercises">

        <%fichaTreinos[0].treinos.forEach(treino=> { %>
            <div class="exercise-card" data-id="<%= treino.idtreino %>">
                <div class="col-ex">

                    <select name="exercicio_id">
                        <% exercicios.forEach(ex=> { %>
                            <option value="<%= ex.idexercicio %>" <%=(treino.exercicio &&
                                ex.idexercicio==treino.exercicio.idexercicio) ? 'selected' : '' %>>
                                <%= ex.nome %>
                            </option>
                            <% }) %>
                        </select>
                    </div>

                <div id="col_serie" class="col-sm"><input type="text" value="<%=treino.serie%>"></div>
                <div id="col_repeticao" class="col-sm"><input type="text" value="<%=treino.repeticoes%>"></div>
                <div id="col_carga" class="col-sm"><input type="text" value="<%=treino.carga%>"></div>

                <div class="col-btns">
                    <button class="btn-delete"> <span class="material-symbols-outlined"
                            onclick="delete_treino(this)">delete</span></button>
                    <button class="btn-update"> <span class="material-symbols-outlined"
                            onclick="update_treino(this)">save</span></button>
                </div>
            </div>
            <% }) %>

                <div class="exercise-create">

                </div>
                <!-- 
         -->
    </main>

    <button class="btn-add-float"> <span class="material-symbols-outlined" onclick="add_treino()">Add</span></button>

    <nav class="bottom-nav">
        <div class="nav-circle" style="width: 45px; height: 45px; position: absolute; left: 20px;">
            <a href="/fichas" style="text-decoration: none; color: inherit;">
                <div class="icon-label">
                    <span class="material-symbols-outlined">arrow_back</span>
                </div>
            </a>
        </div>

        <div class="nav-circle" style="width: 45px; height: 45px;">
            <a href="/home" style="text-decoration: none; color: inherit;">
                <div class="icon-label">
                    <span class="material-symbols-outlined ">home</span>
                </div>
                <p>Home</p>
            </a>
        </div>
    </nav>

</body>
<script src="/javascripts/logout.js"></script>

<script>
    // Converte os dados do EJS para um objeto JS real no navegador
    const exerciciosDisponiveis = <%- JSON.stringify(exercicios) %>;
</script>

<script src="/javascripts/fichaEdicao.js"></script>

</html>